# Database — Neon Postgres pooled connection string
# https://neon.tech
DATABASE_URL=

# Better Auth — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash)
# Dev: http://localhost:3000 | Prod: https://your-domain.vercel.app
BETTER_AUTH_URL=

# Google OAuth 2.0 — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — https://portal.azure.com (App Registration)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Resend email API — https://resend.com
RESEND_API_KEY=

# Google Gemini API — https://aistudio.google.com
GEMINI_API_KEY=

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Blob private store — Vercel dashboard → Storage → Blob → Token
BLOB_READ_WRITE_TOKEN=
